class AngularCustomFilters{static MoneyFilter(r){return AngularCustomFilters.createMoneyFilter(r,window.USER_CURRENCY_SIGN)}static MarketMoneyFilter(r){return AngularCustomFilters.createMoneyFilter(r,window.MARKET_CURRENCY_SIGN)}static createMoneyFilter(r,t){return function(e,n,u=!0,i=2){let o=void 0===n?t:n;"¥"!==o&&"&yen;"!==o||(i=0);let c=e<0?"-":"",a=c+(u?'<span class="currency">'+o+"</span>":o)+("$"===o?"":" ")+(e=AngularCustomFilters.NumberFilter()(Math.abs(e),i));return"د."===o&&(a=c+e+" "+(u?'<span class="currency">'+o+"</span>":o)),u&&r?r.trustAsHtml(a):a}}static CurrencyConversionFilter(r){return function(t,e=window.USER_CURRENCY_SIGN,n=window.MARKET_CURRENCY_CODE,u=window.USER_CURRENCY_CODE){if(n!==u){const i=window.currencyCalcs.convert(t||0,n,u);return AngularCustomFilters.createMoneyFilter(r,e)(i,e)}return AngularCustomFilters.createMoneyFilter(r,e)(t,e)}}static NumberFilter(){return window.formatNumber}}var customFiltersModule=angular.module("customFilters",[]).filter("capitalize",[function(){return function(r){return r.charAt(0).toUpperCase()+r.slice(1)}}]).filter("escapeHTML",["$sce",function(r){return window.escapeHtml}]).filter("commentShortener",["$sce",function(r){return window.commentShortener}]).filter("safeHtml",["$sce",function(r){return function(t){const e=document.createElement("textarea");return e.innerHTML=t,r.trustAsHtml(e.value)}}]).filter("html",["$sce",function(r){return function(t){return r.trustAsHtml(t)}}]).filter("unsafe",["$sce",function(r){return r.trustAsHtml}]).filter("number",function(){return window.formatNumber}).filter("money",["$sce",AngularCustomFilters.MoneyFilter]).filter("converterFromMarketToAccountCurrency",["$sce",AngularCustomFilters.CurrencyConversionFilter]).filter("marketmoney",["$sce",AngularCustomFilters.MarketMoneyFilter]).filter("percent",function(){return function(r){return r+"%"}}).filter("abs",function(){return function(r){return Math.abs(r)}}).filter("percentNumber",function(){return function(r){return"number"==typeof r?r==r.toFixed(0)?r.toFixed(0)+"%":r.toFixed(2)+"%":r+"%"}}).filter("percentNumberWithSign",function(){return function(r){return"number"==typeof r?r==r.toFixed(0)?(r>0?"+":"")+r.toFixed(0)+"%":(r>0?"+":"")+r.toFixed(2)+"%":r}}).filter("number",function(){return window.formatNumber}).filter("numberIntegerPart",function(){return function(r){return r.split(window.numeralDecimalSeparator())[0]}}).filter("numberDecimalPart",function(){return function(r){var t=r.split(window.numeralDecimalSeparator());return t.length>1?window.numeralDecimalSeparator()+t[1]:""}}).filter("reverse",function(){return function(r){return r.slice().reverse()}}).filter("abs",function(){return function(r){return Math.abs(r)}}).filter("range",function(){return function(r,t){t=parseInt(t);for(var e=0;e<t;e++)r.push(e);return r}}).filter("round",function(){return function(r,t){if(isNaN(r)||isNaN(t))return!1;var e=Math.pow(10,t);return Math.round(r*e)/e}}).filter("formatDate",function(){return function(r,t,e=!1){if(""!==t){let n=isNaN(r)?moment(r):moment.unix(r);return e&&n.utc(),window.MOMENTJSFORMATS[t]?n.format(window.MOMENTJSFORMATS[t]):n.format(t)}return window.getDateFormat(r)}});