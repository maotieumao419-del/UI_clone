function getInfoOfError(r){const e=r.message?r.message:String(r);return r&&"object"==typeof r?{name:r.name?r.name:"",class:r.constructor.name,message:e,type:typeof r,stack:r.stack?r.stack.split("\n").map(r=>r.trim()):""}:{message:e,type:typeof r}}function safeStringifyError(r,e,n,o,t){const s={date:new Date,href:location.href,errorInfo:{message:r,source:e,lineno:n,colno:o,error:getInfoOfError(t)}};try{return JSON.stringify(s)}catch(t){const a=s.errorInfo.error||{};return JSON.stringify({date:s.date,href:s.href,errorInfo:{message:String(r),source:String(e),lineno:n,colno:o,error:{name:a.name||"",class:a.class||"",message:String(a.message||""),type:a.type||"",stack:a.stack||""}},stringifyFailed:String(t)})}}window.onerror=function(r,e,n,o,t){$.ajax({url:location.origin+"/index/logError",type:"post",data:{[window.CSRF_TOKEN_KEY]:window.CSRF_TOKEN,data:safeStringifyError(r,e,n,o,t)},success:function(r){console.log("response",r)}})};