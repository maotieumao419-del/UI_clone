$(document).ready(function(){var e=$("#selectProductsWrapper"),c=e.find(".select2-search__field");function s(s){var t=e.data("for-placeholder"),r=s?t.search_open_select:t.search;c.attr("placeholder",r)}$(document).on("focus","#selectProductsWrapper .select2-search__field",function(){e.addClass("active"),s(!0)}),$(document).on("blur","#selectProductsWrapper .select2-search__field",function(c){$(".select2-dropdown").is(":visible")||(e.removeClass("active"),s(!1))}),$(document).on("select2:closing","#selectProductsWrapper select",function(){e.removeClass("active"),s(!1)})});