!function(){var t=null,o=!1,i=null;$(document).ready(function(){window.USER_IS_PRODUCT_COST_RECALCULATING&&window.initProductCostRecalculating()}),window.initProductCostRecalculating=function(){if(window.USER_IS_PRODUCT_COST_RECALCULATING=!0,!t||!t.is(":visible")){notifications.clearMessages("progress_status"),notifications.addMessage({className:"progress_status",text:window.DASHBOARD_IS_PRODUCT_COST_RECALCULATED_MESSAGE,callback:function(o){t=o,window.calcNotifications()},isLoading:!0}),setTimeout(function(){i=setInterval(function(){window.calcNotifications(),window.getProductCostRecalculatedStatus(),o=!0},1e4)},3e3),window.calcNotifications();var n=setInterval(function(){window.calcNotifications(),o&&clearInterval(n)},1e3)}},window.getProductCostRecalculatedStatus=function(){$.ajax({type:"GET",url:window.URLROOT+"/dashboard/getCostUpdateStatus",success:function(t){t.is_product_cost_recalculating||window.clearProductCostRecalculated()},error:function(t,o){console.error(t.responseCode)}})},window.clearProductCostRecalculated=function(){window.USER_IS_PRODUCT_COST_RECALCULATING=!1,t&&t.is(":visible")&&!window.reloadRowId&&t.remove(),clearInterval(i)}}();