# Reverse proxy Nginx cho SellerVision trên VPS (Ubuntu/Debian).
# Đặt tại /etc/nginx/sites-available/sellervision rồi symlink sang sites-enabled.
# HTTPS: chạy `sudo certbot --nginx -d tencuaban.com -d app.tencuaban.com` để tự cấp SSL.

server {
    listen 80;
    server_name tencuaban.com app.tencuaban.com;   # đổi thành domain của bạn

    client_max_body_size 30M;                       # cho phép upload file PPC

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;  # để app biết đang chạy HTTPS
        proxy_read_timeout 120s;
    }
}
