# =====================================================
# PPC Phase 1 — Environment Variables
# Copy sang .env và điền giá trị thật (KHÔNG commit .env)
# =====================================================

# ── Amazon Ads API ─────────────────────────────────
# Thường dùng chung app + refresh token với SP-API nếu đã có scope advertising::campaign_management
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=

# Profile ID của tài khoản quảng cáo Amazon
# Cách lấy: chạy script sau để list tất cả profiles:
#   python -c "
#   import sys, os; sys.path.insert(0, os.path.abspath('../../../'))
#   from shared.amz_auth import get_ads_token
#   from shared.config import ADS_BASE, ADS_CLIENT_ID
#   import requests
#   token = get_ads_token()
#   r = requests.get(ADS_BASE + '/v2/profiles',
#       headers={'Authorization': 'Bearer ' + token,
#                'Amazon-Advertising-API-ClientId': ADS_CLIENT_ID})
#   for p in r.json(): print(p.get('profileId'), p.get('accountInfo',{}).get('name'))
#   "
ADS_PROFILE_ID=

# ── Supabase ────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Tuning (tùy chọn) ──────────────────────────────
SELLER_TIMEZONE=America/Los_Angeles

# Khoảng cách giữa các API call (giây) — tránh throttle
ADS_REQUEST_GAP_SECONDS=20

# Polling report (giây)
ADS_POLL_INTERVAL_SECONDS=15
ADS_POLL_TIMEOUT_SECONDS=600
