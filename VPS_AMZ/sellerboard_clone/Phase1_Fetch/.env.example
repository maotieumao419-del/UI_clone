# =====================================================
# Phase1_Fetch — Environment (gọi API cho CẢ profit + ppc)
# Copy sang .env và điền giá trị thật (KHÔNG commit .env)
# =====================================================

# ── Amazon SP-API (Orders + Finances) ──────────────
AMAZON_SPI_CLIENT_ID=
AMAZON_SPI_CLIENT_SECRET=
AMAZON_SPI_REFRESH_TOKEN=
AMAZON_SPI_MARKETPLACE_ID=ATVPDKIKX0DER

# ── Amazon Ads API (Reports + Campaign Mgmt + Bid Recs) ──
# Thường dùng chung app/refresh token với SP-API nếu có scope advertising
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
ADS_PROFILE_ID=

# ── Timezone (chuẩn Sellerboard) ───────────────────
SELLER_TIMEZONE=America/Los_Angeles

# ── Tuning fetch ───────────────────────────────────
# Giãn cách giữa các lần POST tạo Ads report (throttle rất chặt)
ADS_REQUEST_GAP_SECONDS=20
ADS_POLL_INTERVAL_SECONDS=15
ADS_POLL_TIMEOUT_SECONDS=600

# Giãn cách fetch order items / finances page (SP-API)
ORDER_ITEMS_DELAY_SECONDS=1.0
FINANCES_PAGE_DELAY_SECONDS=1.0

# LƯU Ý: Phase1_Fetch KHÔNG cần SUPABASE_* — chỉ lưu file. SUPABASE_* nằm ở
# .env của Phase1_Upload (mỗi dashboard).
