# Phase1_Upload (profit) — chỉ cần Supabase (KHÔNG cần Amazon credentials)
# Copy sang .env, điền giá trị thật.

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Timezone để parse date_label (khớp Phase1_Fetch)
SELLER_TIMEZONE=America/Los_Angeles

# Cửa sổ trượt giữ trên Supabase (manage_supabase.py prune). Mặc định 62 ngày.
# Dữ liệu cũ hơn vẫn ở archive local, hydrate khi cần.
SUPABASE_WINDOW_DAYS=62
# Ghi đè riêng cho raw nếu cần nhỏ hơn (để trống = bằng SUPABASE_WINDOW_DAYS)
SUPABASE_RAW_WINDOW_DAYS=

# (cleanup dedup dùng DATABASE_URL nếu chạy --cleanup)
DATABASE_URL=
