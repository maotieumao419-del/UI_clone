# ============ CẤU HÌNH SELLERVISION ============
# Sao chép file này thành ".env" rồi điền giá trị THẬT cho domain của bạn.
# (KHÔNG commit file .env chứa bí mật lên Git)

APP_NAME=SellerVision
ENV=prod                       # prod = ẩn /docs, bật bảo mật

# --- Bảo mật (BẮT BUỘC đổi khi lên domain) ---
# Tạo khoá: openssl rand -hex 32     (hoặc python -c "import secrets;print(secrets.token_hex(32))")
SECRET_KEY=DAN_KHOA_BI_MAT_DAI_NGAU_NHIEN_VAO_DAY
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Domain / đầu ra ---
# Domain frontend được phép gọi API (phân tách bằng dấu phẩy). KHÔNG để * ở prod.
CORS_ORIGINS=https://app.tencuaban.com,https://tencuaban.com
# Host được phép phục vụ (chống Host header giả mạo).
ALLOWED_HOSTS=tencuaban.com,app.tencuaban.com

# --- Cơ sở dữ liệu ---
# PRODUCTION (Supabase PostgreSQL — main DB):
# Vào Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Chọn "Session mode" (port 5432) hoặc "Transaction mode" (port 6543 qua Pooler).
# DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# DEV LOCAL (SQLite — không cần cấu hình cloud):
DATABASE_URL=sqlite:///./sellervision.db

# --- PPC ---
# Thư mục lưu file Excel người dùng upload (giữ qua volume khi deploy).
PPC_DIR=data/ppc

# --- Nguồn dữ liệu ---
# "file" = đọc Excel upload (mặc định) · "vst" = gọi API VST · "spi" = SP-API (đấu sau)
DATA_SOURCE=file
# Cache (giây) dữ liệu kéo từ API, tránh gọi API mỗi request. 0 = luôn gọi mới.
VST_CACHE_TTL=300

# --- API VST (điền khi DATA_SOURCE=vst) ---
VST_API_BASE=https://api.vst-provider.com
VST_API_KEY=DAN_KEY_THAT_VAO_DAY
VST_TIMEOUT=30
VST_VERIFY_SSL=true

# --- API SPI / Amazon SP-API (đấu nối sau) ---
SPI_API_BASE=
SPI_API_KEY=

# --- Lịch tự động đồng bộ Amazon ---
# Giờ chạy cố định mỗi ngày, tính theo giờ marketplace (Pacific Time cho US).
# Mặc định: 01:00, 07:00, 13:00, 19:00 (cách 6 tiếng). Phân tách bằng dấu phẩy.
AMAZON_AUTO_SYNC_SCHEDULE_HOURS=1,7,13,19
# Số ngày đơn hàng kéo về mỗi lần sync
AMAZON_AUTO_SYNC_DAYS=3

# --- Supabase (tầng đệm dữ liệu / Data Buffer cho module đồng bộ Orders) ---
# Project Settings > API trên Supabase Dashboard. Dùng service_role key (server-side).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=DAN_SERVICE_ROLE_KEY_VAO_DAY

# --- Khác ---
DATA_RETENTION_DAYS=180
# PORT thường do nền tảng deploy tự set; để trống nếu không chắc.
# PORT=8000
