# ==============================================
# AMAZON SP-API CREDENTIALS
# Xem README.txt Bước 2 để biết cách lấy từng giá trị
# ==============================================

# LWA OAuth — lấy tại developer.amazon.com
AMAZON_SPI_CLIENT_ID=
AMAZON_SPI_CLIENT_SECRET=
AMAZON_SPI_REFRESH_TOKEN=

# Marketplace — mặc định US
AMAZON_SPI_MARKETPLACE_ID=ATVPDKIKX0DER

# AWS IAM — lấy tại AWS Console > IAM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/TEN_ROLE
AWS_REGION=us-east-1

# ==============================================
# AMAZON ADVERTISING API (ADS-API)
# ==============================================

# Refresh token cho Ads API
# Thường CÙNG refresh token với SP-API nếu app có cả 2 scope
# Nếu khác app → điền refresh token riêng
AMAZON_ADS_REFRESH_TOKEN=

# Profile ID của tài khoản quảng cáo
# Cách lấy: chạy python fetch_24h_ads.py khi ADS_PROFILE_ID để trống
# → script sẽ in danh sách profileId tìm thấy
ADS_PROFILE_ID=

# ==============================================
# SUPABASE — đích lưu dữ liệu trực tiếp (NEW_* tables)
# Lấy tại supabase.com → project → Project Settings → API
# ==============================================

# Project URL, dạng https://xxxx.supabase.co
SUPABASE_URL=

# service_role key (KHÔNG phải anon key) — có quyền ghi đầy đủ
# Tuyệt đối KHÔNG commit giá trị thật vào git, chỉ điền trong .env local
SUPABASE_SERVICE_KEY=

# ==============================================
# KHOẢNG THỜI GIAN CALL API (tuỳ chọn — để trống = mặc định 24h/hôm qua)
# ==============================================

# Timezone Sellerboard đang dùng để tính "1 ngày" (Settings → General → Time Zone).
# Mặc định: America/Los_Angeles (phổ biến cho seller US).
# Dùng để quy đổi ngày bạn chọn (khi script hỏi) sang UTC cho Orders/Finances,
# và làm startDate/endDate (đã đúng timezone) cho Ads report.
SELLER_TIMEZONE=America/Los_Angeles

# Áp dụng cho fetch_24h_orders.py (CreatedAfter) và fetch_24h_finances.py (PostedAfter)
# Mặc định 24
LOOKBACK_HOURS=24

# Ghi đè hẳn mốc bắt đầu/kết thúc cho orders/finances (ISO 8601 UTC, vd 2026-06-01T00:00:00Z)
# Để trống nếu dùng LOOKBACK_HOURS ở trên.
# Lưu ý: nếu cả 2 biến ORDERS_CREATED_*/FINANCES_POSTED_* đều để trống VÀ chạy ở
# terminal tương tác (không phải cron) → script sẽ HỎI bạn chọn "24h gần nhất"
# hay "1 ngày cụ thể" (xem _time_range.py).
ORDERS_CREATED_AFTER=
ORDERS_CREATED_BEFORE=
FINANCES_POSTED_AFTER=
FINANCES_POSTED_BEFORE=

# Áp dụng cho fetch_24h_ads.py — số ngày trước hôm nay để lấy report (mặc định 1 = hôm qua)
ADS_DAYS_AGO=1

# Hoặc ghi đè hẳn ngày cần lấy report (YYYY-MM-DD), bỏ qua ADS_DAYS_AGO và prompt hỏi ngày
ADS_REPORT_DATE=
